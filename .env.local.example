# Convex deployment URL used by the Next.js client.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Convex Auth endpoint used for sign-in redirects and callbacks.
CONVEX_SITE_URL=https://your-deployment.convex.site
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Public URL of the web app itself.
SITE_URL=http://localhost:3000

# Optional when working with the Convex CLI against a named deployment.
CONVEX_DEPLOYMENT=

# Required for Convex Auth magic-link email via Resend.
AUTH_RESEND_KEY=
